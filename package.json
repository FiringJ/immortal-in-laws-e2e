{
  "name": "immortal-in-laws-e2e",
  "version": "1.0.0",
  "description": "神仙亲家小程序 E2E 与 Figma MCP 页面样式还原工具",
  "scripts": {
    "test": "npm run verify:typecheck",
    "verify:typecheck": "tsc --noEmit",
    "verify:e2e": "tsx src/tests/run-e2e.ts",
    "verify:calibrate": "tsx src/tools/debug-calibrate.ts",
    "verify:all": "npm run verify:typecheck && npm run verify:e2e",
    "mcp:server": "tsx src/tools/e2e-mcp-server.ts",
    "figma:pages": "tsx figma/data/figma-mcp-pages-list.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nut-tree/nut-js": "^3.1.2",
    "openai": "^6.25.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@midscene/core": "^1.4.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}

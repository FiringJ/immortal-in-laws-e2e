# 飞书 App 凭证（用于优先 reply 原消息 / 同会话发送）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your-feishu-app-secret

# 可选：飞书 OpenAPI 域名（默认 https://open.feishu.cn）
FEISHU_OPEN_BASE_URL=https://open.feishu.cn

# 飞书 Webhook URL（当无法 reply 原消息时的回退通道）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token

# Midscene AI 视觉模型配置（qwen-3.5-plus）
MIDSCENE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MIDSCENE_MODEL_API_KEY=your-dashscope-api-key
MIDSCENE_MODEL_NAME=qwen3.5-plus
MIDSCENE_MODEL_FAMILY=qwen3.5

# Figma Access Token（用于 Figma MCP）
FIGMA_ACCESS_TOKEN=your-figma-token

# 微信开发者工具路径（macOS）
WECHAT_DEVTOOLS_PATH=/Applications/wechatwebdevtools.app

# 小程序项目路径
APP_REPO_PATH=/Users/firingj/Projects/immortal-in-laws

# E2E 项目路径
TRACKER_REPO_PATH=/Users/firingj/Projects/immortal-in-laws-e2e

# Daemon 配置
DAEMON_PORT=3000
DAEMON_DEFAULT_AGENT=codex
DAEMON_WORKSPACE_ROOT=/Users/firingj/Projects/immortal-in-laws-e2e
DAEMON_TASK_TIMEOUT_MS=2700000
DAEMON_NOTIFY_FEISHU=true
DAEMON_NOTIFY_ALL=false
DAEMON_NOTIFY_SUMMARY_MAX=600
# 可选：检测“只给计划就结束”时的自动重试次数（默认 0，避免同任务重复执行）
DAEMON_PLAN_ONLY_RETRY_MAX=0

# 飞书任务默认工作区：app | tracker | auto（默认 app）
DAEMON_FEISHU_DEFAULT_CWD=app

# 飞书事件去重窗口（毫秒）
DAEMON_FEISHU_EVENT_DEDUP_WINDOW_MS=600000

# Agent CLI 路径（可选；默认使用 PATH 中的 codex / claude / cursor-agent）
CODEX_BIN=codex
CLAUDE_BIN=claude
CURSOR_AGENT_BIN=cursor-agent
